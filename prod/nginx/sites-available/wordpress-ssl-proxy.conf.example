# This is the Nginx SSL proxy in front of varnish 127.0.0.1:6081
# Varnish in-turn points to nginx:80 with the CMS

server {
    listen [::]:443 ssl;
    http2 On;
    listen 443 ssl;
    server_name _;

    access_log  /var/log/nginx/wordpress-ssl-proxy-access.log;
    error_log  /var/log/nginx/wordpress-ssl-proxy-error.log;

    # be sure to EDIT ssl/ssl.inc with ssl keys
    include ssl/ssl.inc;

    # not real CMS
    root /var/www/html;

    # detect /index.php to prevent include loops
    rewrite ^/index.php$ /404 last;

    # block front end /admin
    location ~ /wp-admin {
        include htpasswd.inc;
        # Direct to CMS (no varnish)
        proxy_pass http://127.0.0.1:80;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port 443;
        proxy_set_header Host $host;
    }

    location / {
        proxy_buffering off;
        proxy_buffer_size 8k;

#        proxy_cache my_cache;
#        proxy_cache_revalidate on;
#        proxy_cache_min_uses 3;
#        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
#        proxy_cache_background_update on;
#        proxy_cache_lock on;

        proxy_ignore_headers X-Accel-Expires;
        proxy_ignore_headers Expires;
        proxy_ignore_headers Cache-Control;

        # varnish 6081
#        proxy_pass http://127.0.0.1:6081;
       proxy_pass http://127.0.0.1:80;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_set_header X-Forwarded-Port 443;
        proxy_set_header Host $host;
    }

}
